#!/usr/bin/env python3
from __future__ import annotations

from typing import Optional

import rclpy
from rclpy.node import Node
from rclpy.qos import HistoryPolicy, QoSProfile, ReliabilityPolicy
from sensor_msgs.msg import PointCloud2


class PointCloudDownsampler(Node):
    def __init__(self) -> None:
        super().__init__("pointcloud_downsampler")

        self.declare_parameter("input_topic", "/rslidar_points")
        self.declare_parameter("output_topic", "/rslidar_points_web")
        self.declare_parameter("publish_rate_hz", 4.0)
        self.declare_parameter("point_stride", 4)
        self.declare_parameter("max_points", 0)

        self.input_topic = self.get_parameter("input_topic").get_parameter_value().string_value
        self.output_topic = self.get_parameter("output_topic").get_parameter_value().string_value
        self.publish_rate_hz = self.get_parameter("publish_rate_hz").get_parameter_value().double_value
        self.point_stride = max(
            1, self.get_parameter("point_stride").get_parameter_value().integer_value
        )
        self.max_points = max(0, self.get_parameter("max_points").get_parameter_value().integer_value)

        self._last_publish_time: Optional[int] = None
        self._min_period_ns = 0
        if self.publish_rate_hz > 0:
            self._min_period_ns = int(1_000_000_000 / self.publish_rate_hz)

        qos = QoSProfile(
            history=HistoryPolicy.KEEP_LAST,
            depth=1,
            reliability=ReliabilityPolicy.BEST_EFFORT,
        )
        self.publisher = self.create_publisher(PointCloud2, self.output_topic, qos)
        self.subscription = self.create_subscription(
            PointCloud2, self.input_topic, self._on_pointcloud, qos
        )

        self.get_logger().info(
            "Downsampling %s -> %s, publish_rate_hz=%.3f, point_stride=%d, max_points=%d"
            % (
                self.input_topic,
                self.output_topic,
                self.publish_rate_hz,
                self.point_stride,
                self.max_points,
            )
        )

    def _on_pointcloud(self, msg: PointCloud2) -> None:
        now_ns = self.get_clock().now().nanoseconds
        if (
            self._last_publish_time is not None
            and self._min_period_ns > 0
            and now_ns - self._last_publish_time < self._min_period_ns
        ):
            return

        if msg.point_step == 0 or msg.width == 0 or msg.height == 0:
            return

        total_points = msg.width * msg.height
        sampled_indices = range(0, total_points, self.point_stride)
        if self.max_points > 0:
            sampled_indices = list(sampled_indices)[: self.max_points]

        point_step = msg.point_step
        data = bytes(msg.data)
        output_chunks = []
        for index in sampled_indices:
            start = index * point_step
            end = start + point_step
            if end <= len(data):
                output_chunks.append(data[start:end])

        if not output_chunks:
            return

        out = PointCloud2()
        out.header = msg.header
        out.height = 1
        out.width = len(output_chunks)
        out.fields = msg.fields
        out.is_bigendian = msg.is_bigendian
        out.point_step = msg.point_step
        out.row_step = out.width * out.point_step
        out.data = b"".join(output_chunks)
        out.is_dense = msg.is_dense

        self.publisher.publish(out)
        self._last_publish_time = now_ns


def main() -> None:
    rclpy.init()
    node = PointCloudDownsampler()
    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
